# ==========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=chelsancars_db

# ==========================================
# CONFIGURACIÓN DE SERVIDOR
# ==========================================
NODE_ENV=development
PORT=3000

# ==========================================
# CORS — ORÍGENES PERMITIDOS
# ==========================================
# URL del frontend en producción (Netlify)
# Separar con coma si hay más de uno: https://app.com,https://www.app.com
# En desarrollo local no es necesario (usa localhost:5173 por defecto)
ALLOWED_ORIGIN=

# ==========================================
# CONFIGURACIÓN DE JWT
# ==========================================
JWT_SECRET=tu_clave_secreta_super_segura_aqui_CAMBIAR_EN_PRODUCCION
JWT_EXPIRES_IN=24h

# ==========================================
# CREDENCIALES ADMIN
# ==========================================
# OBLIGATORIO: Cambiar por valores seguros antes de desplegar
ADMIN_USER=
ADMIN_PASSWORD=

# ==========================================
# CONFIGURACIÓN DE IA
# ==========================================
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
