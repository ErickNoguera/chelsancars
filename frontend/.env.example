# ==========================================
# CONFIGURACIÓN DE IA
# ==========================================
# Copiar este archivo como .env y completar los valores
# Si VITE_AI_API_KEY está vacío, se usará el modo mock automáticamente

# API Key de tu proveedor de IA
# Ejemplo con OpenAI:      sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
# Ejemplo con Gemini:      AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx
VITE_AI_API_KEY=

# URL del endpoint de tu proveedor de IA
# Ejemplo con OpenAI:      https://api.openai.com/v1/chat/completions
# Ejemplo con Gemini:      https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent
VITE_AI_API_URL=
